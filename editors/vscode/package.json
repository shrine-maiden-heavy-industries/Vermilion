{
	"name": "vermilion",
	"displayName": "Vermilion",
	"description": "Vermilion is a Verilog, Verilog-AMS, SystemVerilog, VHDL, and VHDL-AMS linter and formatter, and language server.",
	"version": "0.0.1",
	"preview": true,
	"publisher": "shrine-maiden-heavy-industries",
	"private": true,
	"license": "BSD-3-Clause",
	"icon": "icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/shrine-maiden-heavy-industries/Vermilion.git"
	},
	"bugs": {
		"url": "https://github.com/shrine-maiden-heavy-industries/Vermilion/issues"
	},
	"categories": [
		"Programming Languages",
		"Linters",
		"Snippets",
		"Formatters",
		"Other"
	],
	"keywords": [
		"Verilog",
		"Verilog-AMS",
		"SystemVerilog",
		"VHDL",
		"VHDL-AMS",
		"HDL",
		"ASIC",
		"FPGA"
	],
	"engines": {
		"vscode": "^1.93.0"
	},
	"main": "./build/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run lint && npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"test": "jest",
		"lint": "eslint --ext ts src",
		"installDevExtension": "npm install && ./node_modules/.bin/vsce package -o ./build/vermilion-dev.vsix && code --install-extension ./build/vermilion-dev.vsix"
	},
	"dependencies": {
		"ts-results": "^3.3.0",
		"tslib":"^2.8.1",
		"vscode-languageclient": "^9.0.1"
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"@types/vscode": "^1.93.0",
		"@typescript-eslint/eslint-plugin": "^8.50.0",
		"@typescript-eslint/parser": "^8.50.0",
		"@stylistic/eslint-plugin": "^5.6.1",
		"eslint": "^9.39.2",
		"jest": "^30.2.0",
		"ts-jest": "^29.4.6",
		"typescript": "~5.5.4",
		"@vscode/vsce": "^3.7.1"
	},
	"activationEvents": [
		"workspaceContains:vermilion.toml",
		"workspaceContains:*/vermilion.toml"
	],
	"contributes": {
		"configuration": [
			{
				"title": "Vermilion",
				"properties": {
					"vermilion.binaryPath": {
						"markdownDescription": "Path to the `vermilion` executable.",
						"default": null,
						"type":"string"
					}
				}
			}
		],
		"grammars": [
			{
				"language": "liberty",
				"scopeName": "source.liberty",
				"path": "./lang/liberty/base.tmLanguage.json"
			},
			{
				"language": "lpf",
				"scopeName": "source.lpf",
				"path": "./lang/lpf/base.tmLanguage.json"
			},
			{
				"language": "pdc",
				"scopeName": "source.pdc",
				"path": "./lang/pdc/base.tmLanguage.json"
			},
			{
				"language": "sdc",
				"scopeName": "source.sdc",
				"path": "./lang/sdc/base.tmLanguage.json"
			},
			{
				"language": "system-verilog",
				"scopeName": "source.system_verilog",
				"path": "./lang/system_verilog/base.tmLanguage.json"
			},
			{
				"language": "verilog",
				"scopeName": "source.verilog",
				"path": "./lang/verilog/base.tmLanguage.json"
			},
			{
				"language": "verilog-ams",
				"scopeName": "source.verilog_ams",
				"path": "./lang/verilog_ams/base.tmLanguage.json"
			},
			{
				"language": "vhdl",
				"scopeName": "source.vhdl",
				"path": "./lang/vhdl/base.tmLanguage.json"
			},
			{
				"language": "vhdl-ams",
				"scopeName": "source.vhdl_ams",
				"path": "./lang/vhdl_ams/base.tmLanguage.json"
			},
			{
				"language": "xdc",
				"scopeName": "source.xdc",
				"path": "./lang/xdc/base.tmLanguage.json"
			}
		],
		"languages": [
			{
				"id": "liberty",
				"extensions": [
					".lib"
				],
				"configuration": "./lang/liberty/configuration.json",
				"icon": {
					"dark": "./lang/liberty/icon_dark.svg",
					"light": "./lang/liberty/icon_light.svg"
				}
			},
			{
				"id": "lpf",
				"extensions": [
					".lpf"
				],
				"configuration": "./lang/lpf/configuration.json",
				"icon": {
					"dark": "./lang/lpf/icon_dark.svg",
					"light": "./lang/lpf/icon_light.svg"
				}
			},
			{
				"id": "pdc",
				"extensions": [
					".pdc"
				],
				"configuration": "./lang/pdc/configuration.json",
				"icon": {
					"dark": "./lang/pdc/icon_dark.svg",
					"light": "./lang/pdc/icon_light.svg"
				}
			},
			{
				"id": "sdc",
				"extensions": [
					".sdc"
				],
				"configuration": "./lang/sdc/configuration.json",
				"icon": {
					"dark": "./lang/sdc/icon_dark.svg",
					"light": "./lang/sdc/icon_light.svg"
				}
			},
			{
				"id": "system-verilog",
				"extensions": [
					".sv",
					".svh"
				],
				"configuration": "./lang/system_verilog/configuration.json",
				"icon": {
					"dark": "./lang/system_verilog/icon_dark.svg",
					"light": "./lang/system_verilog/icon_light.svg"
				}
			},
			{
				"id": "verilog",
				"extensions": [
					".v",
					".vh",
					".vm"
				],
				"configuration": "./lang/verilog/configuration.json",
				"icon": {
					"dark": "./lang/verilog/icon_dark.svg",
					"light": "./lang/verilog/icon_light.svg"
				}
			},
			{
				"id": "verilog-ams",
				"extensions": [
					".vams"
				],
				"configuration": "./lang/verilog_ams/configuration.json",
				"icon": {
					"dark": "./lang/verilog_ams/icon_dark.svg",
					"light": "./lang/verilog_ams/icon_light.svg"
				}
			},
			{
				"id": "vhdl",
				"extensions": [
					".vhdl",
					".vhd"
				],
				"configuration": "./lang/vhdl/configuration.json",
				"icon": {
					"dark": "./lang/vhdl/icon_dark.svg",
					"light": "./lang/vhdl/icon_light.svg"
				}
			},
			{
				"id": "vhdl-ams",
				"extensions": [
					".vhdl",
					".vhd"
				],
				"configuration": "./lang/vhdl_ams/configuration.json",
				"icon": {
					"dark": "./lang/vhdl_ams/icon_dark.svg",
					"light": "./lang/vhdl_ams/icon_light.svg"
				}
			},
			{
				"id": "xdc",
				"extensions": [
					".xdc"
				],
				"configuration": "./lang/xdc/configuration.json",
				"icon": {
					"dark": "./lang/xdc/icon_dark.svg",
					"light": "./lang/xdc/icon_light.svg"
				}
			}
		]
	}
}
