{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Yosys Script",
	"scopeName": "source.ys",
	"fileTypes": [
		"ys"
	],
	"patterns": [
		{ "include": "#yosys-script" }
	],
	"repository": {
		"yosys-script": {
			"patterns": [
				{ "include": "#commands" },
				{ "include": "#common"   }
			]
		},

		"common": {
			"patterns": [
				{ "name": "comment.line.ys", "match": "#.*$" }
			]
		},

		"string": {
			"name": "string.quoted.double.ys",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{ "name": "constant.character.escape.ys", "match": "\\\\." }
			]
		},

		"commands": {
			"patterns": [
				{ "include": "#common" },
				{ "include": "#commands-complex" },
				{ "include": "#commands-simple" }
			]
		},

		"commands-simple": {
			"begin": "^([a-zA-Z][a-zA-Z_]*)",
			"end": "$",
			"beginCaptures": {
				"0": { "name": "entity.name.function.ys" }
			},
			"patterns": [
				{ "include": "#string" },
				{
					"match": "(-[a-zA-Z0-9][a-zA-Z0-9_]*)(\\s+[a-zA-Z0-9_]*)?",
					"captures": {
						"1": { "name": "keyword.ys" },
						"2": { "name": "variable.parameter.ys" }
					}
				}
			]
		},

		"commands-complex": {
			"patterns": [
				{ "include": "#command-read_aiger"   },
				{ "include": "#command-read_blif"    },
				{ "include": "#command-read_json"    },
				{ "include": "#command-read_liberty" },
				{ "include": "#command-read_rtlil"   },
				{ "include": "#command-read_verilog" },
				{ "include": "#command-read_xaiger2" },
				{ "include": "#command-read"         },
				{ "include": "#command-select"       },
				{ "include": "#command-verific"      },
				{ "include": "#command-write_file"   }
			]
		},

		"command-read_aiger": {
			"begin": "^(read_aiger)\\s+((-[a-zA-Z0-9_]+)(\\s+[a-zA-Z0-9]+)?\\s+)*?(<<)\\s*([a-zA-Z_][a-zA-Z_]*)",
			"end": "^(?:\\6)(?=\\s*)",
			"beginCaptures": {
				"1": { "name": "entity.name.function.ys" },
				"3": { "name": "variable.name.ys" },
				"4": { "name": "variable.parameter.ys" },
				"5": { "name": "keyword.operator.heredoc.ys" },
				"6": { "name": "variable.name.ys" }
			},
			"endCaptures": {
				"0": { "name": "variable.name.ys" }
			},
			"patterns": [
				{
					"name": "meta.embedded.block.aiger",
					"patterns": [
						{ "include": "source.aiger" }
					]
				}
			]
		},
		"command-read_blif": {
			"begin": "^(read_blif)\\s+((-[a-zA-Z0-9_]+)(\\s+[a-zA-Z0-9]+)?\\s+)*?(<<)\\s*([a-zA-Z_][a-zA-Z_]*)",
			"end": "^(?:\\6)(?=\\s*)",
			"beginCaptures": {
				"1": { "name": "entity.name.function.ys" },
				"3": { "name": "variable.name.ys" },
				"4": { "name": "variable.parameter.ys" },
				"5": { "name": "keyword.operator.heredoc.ys" },
				"6": { "name": "variable.name.ys" }
			},
			"endCaptures": {
