		"command-write_file": {
			"begin": "^(write_file)\\s+((-[a-zA-Z0-9_]+)(\\s+[a-zA-Z0-9]+)?\\s+)*?(<<)\\s*([a-zA-Z_][a-zA-Z_]*)",
			"end": "^(?:\\6)(?=\\s*)",
			"beginCaptures": {
