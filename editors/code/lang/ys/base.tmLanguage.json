			]
		},
		"command-read": {
			"begin": "^(read)\\s+((-[a-zA-Z0-9_]+)(\\s+[a-zA-Z0-9]+)?\\s+)*?(<<)\\s*([a-zA-Z_][a-zA-Z_]*)",
			"end": "^(?:\\6)(?=\\s*)",
			"beginCaptures": {
				"1": { "name": "entity.name.function.ys" },
				"3": { "name": "variable.name.ys" },
				"4": { "name": "variable.parameter.ys" },
				"5": { "name": "keyword.operator.heredoc.ys" },
				"6": { "name": "variable.name.ys" }
			},
			"endCaptures": {
				"0": { "name": "variable.name.ys" }
			}
		},
		"command-select": {
			"begin": "^(select)\\s+((-[a-zA-Z0-9_]+)(\\s+[a-zA-Z0-9]+)?\\s+)*?",
			"end": "$",
			"beginCaptures": {
				"1": { "name": "entity.name.function.ys" },
				"3": { "name": "variable.name.ys" },
				"4": { "name": "variable.parameter.ys" }
			},
			"patterns": [
				{ "include": "#select-syntax.ys" }
			]
		},
		"command-verific": {
			"begin": "^(verific)\\s+((-[a-zA-Z0-9_]+)(\\s+[a-zA-Z0-9]+)?\\s+)*?(<<)\\s*([a-zA-Z_][a-zA-Z_]*)",
			"end": "^(?:\\6)(?=\\s*)",
			"beginCaptures": {
				"1": { "name": "entity.name.function.ys" },
				"3": { "name": "variable.name.ys" },
				"4": { "name": "variable.parameter.ys" },
				"5": { "name": "keyword.operator.heredoc.ys" },
