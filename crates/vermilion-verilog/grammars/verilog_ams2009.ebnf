	;

queue_id =
	integer_expression
	;

job_id =
	integer_expression
	;

inform_id =
	integer_expression
	;

queue_type =
	"1" | "2"
	;

queue_status_code =
	"1" | "2" | "3" | "4" | "5" | "6"
	;

queue_status_value =
	integer_expression
	;

status =
	integer_expression
	;

