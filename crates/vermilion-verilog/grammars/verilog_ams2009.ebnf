digital_distribution_functions =
	"$", "dist_uniform", "(", dist_seed, ",", dist_start, ",", dist_end, ")", ";" |
	"$", "dist_normal", "(", dist_seed, ",", dist_mean, ",", dist_stddev, ")", ";" |
	"$", "dist_exponential", "(", dist_seed, ",", dist_mean, ")", ";" |
	"$", "dist_poisson", "(", dist_seed, ",", dist_mean, ")", ";" |
	"$", "dist_chi_square", "(", dist_seed, ",", degree_of_freedom, ")", ";" |
	"$", "dist_t", "(", dist_seed, ",", degree_of_freedom, ")", ";" |
	"$", "dist_erlang", "(", dist_seed, ",", k_stage, ",", dist_mean, ")", ";"
	;

(* See NOTE 4 *)
analog_distribution_functions =
	"$", "rdist_uniform", "(", dist_seed, ",", dist_start, ",", dist_end, [ ",", type_string ], ")", ";" |
	"$", "rdist_normal", "(", dist_seed, ",", dist_mean, ",", dist_stddev, [ ",", type_string ], ")", ";" |
	"$", "rdist_exponential", "(", dist_seed, ",", dist_mean, [ ",", type_string ], ")", ";" |
	"$", "rdist_poisson", "(", dist_seed, ",", dist_mean, [ ",", type_string ], ")", ";" |
	"$", "rdist_chi_square", "(", dist_seed, ",", degree_of_freedom, [ ",", type_string ], ")", ";" |
	"$", "rdist_t", "(", dist_seed, ",", degree_of_freedom, [ ",", type_string ], ")", ";" |
	"$", "rdist_erlang", "(", dist_seed, ",", k_stage, ",", dist_mean, [ ",", type_string ], ")", ";"
	;

dist_seed =
	integer_variable_identifier |
	integer_parameter_identifier |
	decimal_number
	;

dist_start =
	integer_expression
	;

dist_end =
	integer_expression
	;

dist_mean =
	integer_expression
	;

dist_stddev =
	integer_expression
	;

degree_of_freedom =
	integer_expression
	;

k_stage =
