	;

(* See NOTE 4 *)
dumpportsall_task =
	"$", "dumpportsall", "(", dumpfile_filename, ")", ";"
	;

(* See NOTE 4 *)
dumpportslimit_task =
	"$", "dumpportslimit", "(", unsigned_number, ",", dumpfile_filename, ")", ";"
	;

(* See NOTE 4 *)
dumpportsflush_task =
	"$", "dumpportsflush", "(", dumpfile_filename, ")", ";"
	;

(* Optional System Functions/Tasks *)

(* See NOTE 4 *)
countdrivers =
	"$", "countdrivers", "(", net_identifier, [ ",", net_is_forced,
		",", number_of_01x_drivers, ",", number_of_0_drivers,
		",", number_of_1_drivers, ",", number_of_x_drivers,
		], ")", ";"
	;

net_is_forced =
	net_identifier
	;

number_of_01x_drivers =
	net_identifier
	;

number_of_0_drivers =
	net_identifier
	;

number_of_1_drivers =
	net_identifier
	;

number_of_x_drivers =
	net_identifier
	;

(* See NOTE 4 *)
getpattern =
	"$", "getpattern", "(", mem_element, ")", ";"
	;

mem_element =
	memory_identifier
	;

(* See NOTE 4 *)
input =
	"$", "input", "(", '"', filename, '"', ")", ";"
	;

(* See NOTE 4 *)
key =
	"$", "key", [ "(", '"', filename, '"', ")" ], ";"
	;

(* See NOTE 4 *)
nokey =
	"$", "nokey", ";"
	;

(* See NOTE 4 *)
list =
	"$", "list", [ "(", hierarchical_name, ")" ], ";"
	;

(* See NOTE 4 *)
log =
	"$", "log", [ "(", '"', filename, '"', ")" ], ";"
	;

(* See NOTE 4 *)
nolog =
	"$", "nolog", ";"
	;

(* See NOTE 4 *)
reset =
	"$", "reset", [ "(", stop_value, [ ",", reset_value, [ ",", diagnostics_value ] ], ")" ], ";"
	;

stop_value =
	constant_expression
	;

reset_value =
	net_identifier
	;

reset_value =
	diagnostics_value
	;

(* See NOTE 4 *)
reset_count =
	"$", "reset_count", ";"
	;

(* See NOTE 4 *)
reset_value =
	"$", "reset_value", ";"
	;

(* See NOTE 4 *)
save =
	"$", "save", "(", '"', filename, '"', ")", ";"
	;

(* See NOTE 4 *)
restart =
	"$", "restart", "(", '"', filename, '"', ")", ";"
	;

(* See NOTE 4 *)
incsave =
	"$", "incsave", "(", '"', filename, '"', ")", ";"
	;

(* See NOTE 4 *)
scale =
	"$", "scale", "(", hierarchical_name, ")", ";"
	;

(* See NOTE 4 *)
scope =
	"$", "scope", "(", hierarchical_name, ")", ";"
	;

(* See NOTE 4 *)
showscopes =
	"$", "showscopes", [ "(", unsigned_number, ")" ], ";"
	;

(* See NOTE 4 *)
showvars =
	"$", "showvars", [ "(", list_of_variables, ")" ], ";"
	;

list_of_variables =
	net_identifier, { ",", net_identifier }
	;

(* See NOTE 4 *)
sreadmemb =
	"$", "sreadmemb", "(", mem_name, ",", start_address, ",", finish_address, ",",
		string, { ",", string },  ")", ";"
	;

(* See NOTE 4 *)
sreadmemh =
	"$", "sreadmemh", "(", mem_name, ",", start_address, ",", finish_address, ",",
		string, { ",", string },  ")", ";"
	;

mem_name =
	memory_identifier
	;

start_address =
	unsigned_number
	;

finish_address =
	unsigned_number
	;

