table_model_function =
	"$", "table_model", "(", table_inputs, ",", table_data_source, ",", table_control_string, ")"
	;

table_inputs =
	expression, [ ",", second_dimension_expression, [ ",", nth_dimension_expression ] ]
	;

table_data_source =
	file_name | table_model_array
	;

file_name =
	string_literal | string_paramter
	;

table_model_array =
	first_dimension_array_identifier, [ ",", second_dimension_array_identifier,
		[ ",", nth_dimension_array_identifier ] ], ",", output_array_identifier
	;

table_control_string =
	'"', [ interp_control, [ ";", dependent_selector ] ], '"'
	;

interp_control =
	[ first_dim_table_ctrl_substr, [ ",", second_dim_table_ctrl_substr,
		[ ",", nth_dim_table_ctrl_substr ] ] ]
	;

table_ctrl_substr =
	[ table_interp_char, [ table_extrap_char, [ higher_table_extrap_char ] ] ]
	;

table_interp_char =
	"I" | "D" | "1" | "2" | "3"
	;

table_extrap_char =
	"C" | "L" | "E"
	;

